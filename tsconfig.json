{
    "extends": "./configs/tsconfigs/tsconfig.base.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "paths": {
            "@main/*": ["./src/main/*"],
            "@preload/*": ["./src/preload/*"],
            "@renderer/*": ["./src/renderer/*"],
            "@shared/*": ["./src/shared/*"]
        },
        "rootDir": "src",

        "plugins": [
            {
                "name": "typescript-plugin-css-modules",
                "options": {
                    // It seems there is no way to support named exports for css modules in *.d.ts,
                    // so for this plugin, disable this option.
                    // ref: https://github.com/mrmckeb/typescript-plugin-css-modules#options
                    "namedExports": false
                }
            }
        ]
    },
    "include": ["src/**/*"],
    "exclude": [],
    "references": [{ "path": "./tsconfig.vite.json" }]
}
