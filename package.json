{
    "name": "template-electron-react",
    "version": "0.16.0",
    "description": "A template project for developing electron application, using react and typescript.",
    "main": "build/electron.js",
    "homepage": "https://github.com/yifanwww/template-electron-react#readme",
    "author": "yifanwww <yifanw1101@gmail.com> (https://github.com/yifanwww)",
    "bugs": {
        "url": "https://github.com/yifanwww/template-electron-react/issues"
    },
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/yifanwww/template-electron-react.git"
    },
    "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316",
    "scripts": {
        "build": "concurrently -n main,renderer \"pnpm run build:main\" \"pnpm run build:renderer\"",
        "build:main": "webpack --config webpack.main.config.mjs --mode production",
        "build:renderer": "vite build --config vite.renderer.config.mjs --base=./",
        "clean": "pnpm run clean:build && pnpm run clean:dev",
        "clean:build": "rimraf build release",
        "clean:dev": "rimraf coverage node_modules/.cache node_modules/.vite",
        "dev": "concurrently -n main,renderer \"pnpm run dev:main\" \"pnpm run dev:renderer\"",
        "dev:main": "webpack --config webpack.main.config.mjs --mode development",
        "dev:renderer": "vite dev --config vite.renderer.config.mjs",
        "format": "prettier --write \"**/*.{cjs,cts,css,html,js,jsx,mjs,mts,json,less,scss,ts,tsx,yaml,yml}\"",
        "gen-installer": "electron-builder build --config electron-builder.json --win --publish never",
        "lint": "pnpm run lint:eslint --fix && pnpm run lint:stylelint --fix",
        "lint:eslint": "eslint .",
        "lint:stylelint": "stylelint \"**/*.{css,scss}\"",
        "lint-ci": "pnpm run lint:eslint && pnpm run lint:stylelint",
        "prepare": "husky && node ./scripts/mkdir-working.mjs",
        "preview": "node ./scripts/preview.mjs",
        "run-bundled": "node ./scripts/run-bundled.mjs",
        "test": "node ./scripts/unit-test.mjs --onlyChanged",
        "test-ci": "node ./scripts/unit-test.mjs --coverage",
        "typecheck": "pnpm run typecheck:src && pnpm run typecheck:vite",
        "typecheck:src": "tsc --project tsconfig.json --noEmit --incremental false",
        "typecheck:vite": "tsc --project tsconfig.vite.json --noEmit --incremental false --composite false"
    },
    "engines": {
        "node": ">=24"
    },
    "dependencies": {
        "chalk": "^5.6.2",
        "clsx": "^2.1.1",
        "dayjs": "^1.11.19",
        "electron-devtools-installer": "^4.0.0",
        "electron-store": "^11.0.2",
        "es-toolkit": "^1.45.1",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "react-router": "^7.11.0",
        "web-vitals": "^5.1.0",
        "winston": "^3.19.0",
        "yargs-parser": "^22.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@jest/globals": "^30.2.0",
        "@jest/types": "^30.2.0",
        "@swc/jest": "^0.2.39",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.1",
        "@testing-library/user-event": "^14.6.1",
        "@types/confusing-browser-globals": "^1.0.3",
        "@types/node": "^24.10.9",
        "@types/react": "^19.2.8",
        "@types/react-dom": "^19.2.3",
        "@types/text-table": "^0.2.5",
        "@types/yargs-parser": "^21.0.3",
        "@vitejs/plugin-react": "^5.1.2",
        "camelcase": "^9.0.0",
        "concurrently": "^9.2.1",
        "confusing-browser-globals": "^1.0.11",
        "electron": "40.1.0",
        "electron-builder": "^26.7.0",
        "esbuild-loader": "^4.4.2",
        "eslint": "^9.39.2",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.12.1",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "fork-ts-checker-webpack-plugin": "^9.1.0",
        "globals": "^17.0.0",
        "husky": "^9.1.7",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "jest-watch-typeahead": "^3.0.1",
        "jsonc-parser": "^3.3.1",
        "lint-staged": "^16.2.7",
        "postcss": "^8.5.6",
        "prettier": "3.7.4",
        "rimraf": "^6.1.2",
        "sass": "^1.97.1",
        "source-map-loader": "^5.0.0",
        "stylelint": "^16.26.1",
        "stylelint-config-recess-order": "^7.4.0",
        "stylelint-config-sass-guidelines": "^12.1.0",
        "stylelint-config-standard": "^39.0.1",
        "stylelint-config-standard-scss": "^16.0.0",
        "stylelint-order": "^7.0.1",
        "text-table": "^0.2.0",
        "typescript": "6.0.3",
        "typescript-eslint": "^8.59.0",
        "typescript-plugin-css-modules": "^5.2.0",
        "vite": "^7.3.0",
        "vite-plugin-checker": "^0.12.0",
        "vite-tsconfig-paths": "^6.0.3",
        "webpack": "^5.104.1",
        "webpack-cli": "^6.0.1",
        "whatwg-fetch": "^3.6.20"
    }
}
