{
    "name": "template-electron-react",
    "version": "0.16.0",
    "description": "A template project for developing electron application, using react and typescript.",
    "main": "build/electron.js",
    "homepage": "https://github.com/yifanwww/template-electron-react#readme",
    "author": "yifanwww <yifanw1101@gmail.com> (https://github.com/yifanwww)",
    "bugs": {
        "url": "https://github.com/yifanwww/template-electron-react/issues"
    },
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/yifanwww/template-electron-react.git"
    },
    "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316",
    "scripts": {
        "build": "pnpm run --recursive --stream build",
        "build-libs": "pnpm run --filter @app/* --filter=!@app/main --filter=!@app/renderer --stream build",
        "clean": "pnpm run clean:build && pnpm run clean:packages",
        "clean:build": "rimraf build release",
        "clean:packages": "pnpm run --recursive --no-sort clean",
        "dev": "concurrently -n main,renderer \"pnpm run dev:main\" \"pnpm run dev:renderer\"",
        "dev:main": "pnpm run --filter @app/main dev",
        "dev:renderer": "pnpm run --filter @app/renderer dev",
        "format": "pnpm run format:root && pnpm run format:workspaces",
        "format:root": "prettier --write \"**/*.{cjs,cts,css,html,js,jsx,mjs,mts,json,less,scss,ts,tsx,yaml,yml}\"",
        "format:workspaces": "pnpm run --recursive --no-sort --stream format",
        "gen-installer": "electron-builder build --config electron-builder.json --win --publish never",
        "lint": "pnpm run --recursive --no-sort --stream lint",
        "lint-fix": "pnpm run --recursive --no-sort --stream lint-fix",
        "prepare": "husky",
        "prepare-env": "node ./scripts/mkdir-working.mjs",
        "run-build": "node ./scripts/run-build.mjs",
        "run-unpacked": "node ./scripts/run-unpacked.mjs",
        "test-full": "pnpm run --recursive --no-sort --stream test-full",
        "typecheck": "pnpm run --recursive --no-sort --stream typecheck"
    },
    "engines": {
        "node": ">=24"
    },
    "devDependencies": {
        "@eslint/js": "catalog:",
        "@jest/types": "catalog:",
        "@swc/jest": "catalog:",
        "@types/confusing-browser-globals": "catalog:",
        "@types/node": "catalog:",
        "@types/text-table": "catalog:",
        "camelcase": "catalog:",
        "chalk": "catalog:",
        "concurrently": "catalog:",
        "confusing-browser-globals": "catalog:",
        "electron": "catalog:",
        "electron-builder": "catalog:",
        "esbuild-loader": "catalog:",
        "eslint": "catalog:",
        "eslint-plugin-import": "catalog:",
        "eslint-plugin-jest": "catalog:",
        "eslint-plugin-prettier": "catalog:",
        "eslint-plugin-react": "catalog:",
        "eslint-plugin-react-hooks": "catalog:",
        "fork-ts-checker-webpack-plugin": "catalog:",
        "globals": "catalog:",
        "husky": "catalog:",
        "identity-obj-proxy": "catalog:",
        "jest": "catalog:",
        "jest-environment-jsdom": "catalog:",
        "jest-watch-typeahead": "catalog:",
        "jsonc-parser": "catalog:",
        "lint-staged": "catalog:",
        "prettier": "catalog:",
        "rimraf": "catalog:",
        "source-map-loader": "catalog:",
        "text-table": "catalog:",
        "typescript": "catalog:",
        "typescript-eslint": "catalog:",
        "webpack": "catalog:",
        "whatwg-fetch": "catalog:"
    }
}
